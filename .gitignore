# Local clone of the love2d MCP bridge — checked out per-developer, not vendored.
love2d-mcp/

# macOS
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp

# Node (in case we add JS tooling later)
node_modules/

# Lua bytecode
*.luac

# Local LuaRocks install tree (developer-installed busted, luacheck, …)
.luarocks/

# Packaged game artifact produced by `make package` / CI
*.love

# LuaCov artifacts produced by `make coverage`. The threshold gate
# reads luacov.report.out at runtime; both files are ephemeral and
# never committed.
luacov.stats.out
luacov.report.out
